<p local-id=3D"9c4d0a147e56"><strong>Webhook requirements:</strong></p>
<ul local-id=3D"bb8da09a-bd31-4e00-aa1a-4d18610b6b0a">
<li local-id=3D"bedbe31d-c102-4308-be18-eab433f6c09d">
<p local-id=3D"8e2378e56487">HMAC signature verification</p></li>
<li local-id=3D"4f972b3f-e59a-4196-a929-f3a4d13f90be">
<p local-id=3D"8e5101b2d204">Retry with exponential backoff</p></li>
<li local-id=3D"0f3563df-7103-4fe1-8be6-cc06dd63fd6e">
<p local-id=3D"84ac324ca06b">Idempotency keys</p></li>
<li local-id=3D"dca62276-c558-47e3-8c96-98d94e4210e2">
<p local-id=3D"4d42f57bf554">Delivery within 60 seconds</p></li>
</ul>
<hr local-id=3D"7bb96c4e-9167-4971-a892-25fd051c19ff">
