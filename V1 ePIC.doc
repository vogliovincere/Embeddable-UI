nceTd">
<p local-id=3D"6410211a61ea">Joint account type</p></td>
<td data-local-id=3D"fd1a0478-cf12-456b-8b99-2a281104661c" class=3D"conflue=
nceTd">
<p local-id=3D"f9185c465b8b"><code>JTWROS</code> / <code>TIC</code></p></td=
>
<td data-local-id=3D"4bcd71f6-ecd1-474a-b3c0-3eb7c7a5000a" class=3D"conflue=
nceTd">
<p local-id=3D"8fe0281cc393">Joint path only</p></td>
</tr>
<tr data-local-id=3D"5ffd0563-478d-435b-8e60-f162a2fd17e2">
<td data-local-id=3D"986f5a95-25d4-43a3-81c5-66bca51edebc" class=3D"conflue=
nceTd">
<p local-id=3D"a81fa8e9816c">Number of holders</p></td>
<td data-local-id=3D"5263c633-22a8-45a1-9441-caf232e66df3" class=3D"conflue=
nceTd">
<p local-id=3D"42016d0002e1">2=E2=80=935</p></td>
<td data-local-id=3D"3a7d882b-855e-48f6-bb67-bfbbecb02492" class=3D"conflue=
nceTd">
<p local-id=3D"01b62565662d">Joint path only</p></td>
</tr>
<tr data-local-id=3D"ad5e86a1-d403-477a-94ed-45410574da93">
<td data-local-id=3D"2328e665-e76e-4f46-a6f6-dc6ef6db1179" class=3D"conflue=
nceTd">
<p local-id=3D"d80a77989fe3">Organization ID</p></td>
<td data-local-id=3D"912e4483-8cfa-41af-ac20-2dd55295977d" class=3D"conflue=
nceTd">
